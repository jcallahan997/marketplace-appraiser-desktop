{
  "name": "marketplace-appraiser-electron",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "author": "James Callahan",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.jcallahan.marketplace-appraiser",
    "productName": "Marketplace Appraiser",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "target": "dir"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
