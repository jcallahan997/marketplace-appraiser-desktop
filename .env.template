# --- LLM Provider ---
# Set to use Claude API (recommended). Leave blank for Ollama fallback.
ANTHROPIC_API_KEY=

# Override default models (optional):
# TEXT_MODEL=claude-sonnet-4-20250514
# VISION_MODEL=claude-sonnet-4-20250514

# --- Search ---
# Tavily API key for web search (falls back to DuckDuckGo if not set)
TAVILY_API_KEY=

# --- Chrome CDP ---
# URL for Chrome remote debugging (default: http://localhost:9222)
# CHROME_CDP_URL=http://localhost:9222

# --- Email (optional) ---
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# EMAIL_TO=recipient@example.com

# --- Observability (optional) ---
# Langfuse tracing for LLM calls, token usage, and latency.
# Use cloud (https://cloud.langfuse.com) or self-hosted via docker-compose.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Docker Compose Defaults ---
# These are pre-configured when using `docker-compose up`.
# Override only if running services differently.
#
# Use host Chrome (recommended for Facebook login):
#   CHROME_CDP_URL=http://host.docker.internal:9222
# Use containerized Chrome (headless, no Facebook session):
#   CHROME_CDP_URL=http://chrome:9222
#
# Self-hosted Langfuse (auto-provisioned keys in docker-compose.yml):
#   LANGFUSE_PUBLIC_KEY=pk-lf-local
#   LANGFUSE_SECRET_KEY=sk-lf-local
#   LANGFUSE_HOST=http://langfuse:3000
#
# Ollama (uncomment ollama service in docker-compose.yml):
#   OLLAMA_HOST=http://ollama:11434

# --- Debug ---
# SCRAPER_DEBUG_SCREENSHOTS=true
